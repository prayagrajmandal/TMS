{
  "name": "tms-split-workspace",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "python -m uvicorn main:app --app-dir backend --host 0.0.0.0 --port 8000 --reload",
    "build": "node scripts/build.js",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "python -m py_compile backend/main.py",
    "start": "node scripts/start.js",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "python -m uvicorn main:app --app-dir backend --host 0.0.0.0 --port 8000"
  }
}
